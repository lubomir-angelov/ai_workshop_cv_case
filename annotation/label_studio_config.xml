<!--
  Label Studio labeling configuration for pickup/putdown temporal event annotation.

  This is the single shared configuration used by every annotator.
  See docs/ANNOTATION_WORKFLOW.md and annotation/README.md for operating procedure.

  Controls:
    - TimelineLabels (pickup, putdown, ignore) for interval annotation
    - Per-region confidence, hard_case, item_count, review_status
    - Task-level complete_active_span_reviewed confirmation
-->

<View>
  <!-- Task metadata (hidden from annotator, carried in export) -->
  <Header value="Pickup/Putdown Annotation" />
  <Text name="clip_info" value="$clip_id" visible="false" />
  <Text name="fps_info" value="$fps" visible="false" />
  <Text name="active_span_info" value="$active_start_s-$active_end_s" visible="false" />

  <!-- Annotation guidance -->
  <Header value="Guidance" visible="true">
    <p>
      <strong>Pickup:</strong> Person removes an item from a shelf/surface and takes it into hand(s).
    </p>
    <p>
      <strong>Putdown:</strong> Person places an item back onto a shelf/surface and releases it.
    </p>
    <p>
      <strong>Ignore:</strong> Transfer evidence is unavailable (fully occluded or out-of-frame).
      Do NOT use ignore for low-confidence visible events or visible restocking.
    </p>
    <p>
      <strong>Restocking:</strong> Visible restocking is NOT putdown. Mark as background/hard negative.
    </p>
    <p>
      <strong>Two items at once:</strong> Create two separate events with the same interval.
    </p>
    <p>
      <strong>Immediate pickup then putdown:</strong> Create two ordered events.
    </p>
    <p>
      <strong>Confidence:</strong> high = clear, med = likely, low = visible but uncertain.
    </p>
    <p>
      <strong>Hard case:</strong> Set to true for difficult but labelable cases.
    </p>
    <p>
      <strong>Review the complete active span</strong> even when candidate suggestions are present.
      Candidates are suggestions only — they must never be imported as ground truth.
    </p>
  </Header>

  <!-- Video timeline for interval annotation -->
  <TimelineLabels name="labels" toName="video" per_region="true">
    <Label value="pickup" background="#4CAF50" />
    <Label value="putdown" background="#2196F3" />
    <Label value="ignore" background="#FF9800" />
  </TimelineLabels>

  <Video name="video" value="$video" framerate="$fps" />

  <!-- Per-region controls (appear when a region is selected) -->
  <RectangleLabels name="confidence" toName="video" per_region="true">
    <Label value="high" background="#4CAF50" />
    <Label value="med" background="#FFC107" />
    <Label value="low" background="#F44336" />
  </RectangleLabels>

  <RectangleLabels name="hard_case" toName="video" per_region="true">
    <Label value="true" background="#9C27B0" />
    <Label value="false" background="#607D8B" />
  </RectangleLabels>

  <Choices name="item_count" toName="video" per_region="true" choice="single-radio">
    <Label value="1" />
    <Label value="2" />
    <Label value="3" />
    <Label value="4+" />
  </Choices>

  <Choices name="review_status" toName="video" per_region="true" choice="single-radio">
    <Label value="draft" />
    <Label value="reviewed" />
    <Label value="accepted" />
    <Label value="needs_adjudication" />
  </Choices>

  <TextArea name="notes" toName="video" per_region="true" editable="true"
            maxSubmissions="1" rows="2" placeholder="Optional notes for this region...">
  </TextArea>

  <!-- Task-level confirmation -->
  <Header value="Review Confirmation" visible="true">
    <p>
      I have reviewed the complete active span for this clip.
      Check the box below to confirm.
    </p>
  </Header>
  <Checkbox name="complete_active_span_reviewed" toName="video"
            value="true" choice="single-radio">
    <Label value="true" />
  </Checkbox>

  <!-- Hidden metadata fields for export -->
  <Hidden name="meta_clip_id" value="$clip_id" />
  <Hidden name="meta_fps" value="$fps" />
  <Hidden name="meta_annotator" value="$annotator" />
</View>
